# Backend API origin. Leave unset in dev — Vite proxies /api and /ws to
# http://localhost:5000. Set to the deployed backend origin if you're not
# relying on the Vercel rewrite in vercel.json.
VITE_API_URL=

# Firebase Web App config — Firebase console → Project settings → Your apps.
# Used only for the Google sign-in popup (src/lib/firebase.ts); the resulting
# ID token is exchanged with the backend at POST /api/v1/auth/google.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=

# Supabase project config — used only by the (currently unwired) waitlist
# table migration in supabase/migrations/.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
