{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://forgefy.onrender.com/api/:path*" },
    { "source": "/ws/:path*", "destination": "https://forgefy.onrender.com/ws/:path*" },
    { "source": "/(.*)", "destination": "/_shell.html" }
  ]
}
